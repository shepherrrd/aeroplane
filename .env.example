PORT=4310
HOST=0.0.0.0
PUBLIC_URL=http://localhost:5173
CONTROL_PLANE_HOSTNAME=
DATA_DIR=./data
DEPLOY_DRY_RUN=false
DEPLOY_HOST_PORT_START=4100
DEPLOY_HOST_PORT_END=4999
AEROPLANE_RUNTIME_NETWORK=aeroplane-runtime
BUILDKIT_HOST=tcp://127.0.0.1:1234
CADDY_CONFIG_PATH=./data/Caddyfile
CADDY_RELOAD_CMD=caddy reload --config ./data/Caddyfile
AEROPLANE_UPDATE_REPO_URL=https://github.com/xt42io/aeroplane.git
AEROPLANE_UPDATE_BRANCH=main
# Optional. Example: systemctl restart aeroplane
AEROPLANE_UPDATE_RESTART_CMD=
# Docker image installs use this commit to compare pending updates.
AEROPLANE_COMMIT_SHA=
# Optional. Defaults to a self-updater container using /opt/aeroplane.
AEROPLANE_IMAGE=ghcr.io/xt42io/aeroplane:latest
AEROPLANE_INSTALL_DIR=/opt/aeroplane
AEROPLANE_IMAGE_UPDATE_CMD=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Temporary fallback only. Prefer the GitHub App settings above.
# GITHUB_ACCESS_TOKEN=

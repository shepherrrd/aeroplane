---
const navItems = [
  { label: "Install", href: "#install" },
  { label: "Features", href: "#features" },
  { label: "Backups", href: "#backups" },
];
---

<header class="aero-container flex items-center justify-between py-6">
  <a href="/" class="flex items-center gap-3 font-bold">
    <span class="grid size-10 place-items-center border border-[var(--aero-border)] bg-[rgba(79,184,178,0.12)]">
      <img src="/favicon.svg" alt="" class="size-5" />
    </span>
    <span>Aeroplane</span>
  </a>

  <nav class="hidden items-center gap-6 text-sm text-[var(--aero-muted)] md:flex">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>

  <a
    class="aero-button secondary hidden md:inline-flex"
    data-analytics-event="github_link_clicked"
    data-analytics-placement="site_header"
    href="https://github.com/akinloluwami/aeroplane"
  >
    GitHub
  </a>
</header>

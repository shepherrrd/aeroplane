---
const githubUrl = "https://github.com/akinloluwami/aeroplane";
---

<section class="relative overflow-hidden border-t border-[rgba(52,56,67,0.65)] bg-[#08090c] py-24 text-[var(--aero-text)]">
  <div
    class="pointer-events-none absolute inset-0 [background-image:linear-gradient(rgba(255,255,255,0.026)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.026)_1px,transparent_1px)] [background-size:72px_72px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-80 bg-[radial-gradient(ellipse_60%_45%_at_50%_0%,rgba(79,184,178,0.14),transparent)]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto grid w-[min(1180px,calc(100%_-_40px))] gap-10 border border-[rgba(52,56,67,0.8)] bg-[rgba(17,19,24,0.5)] p-8 sm:p-10 lg:grid-cols-[1fr_auto] lg:items-center">
    <div>
      <h2 class="font-hero m-0 text-[clamp(2.25rem,5vw,5rem)] font-bold leading-none text-zinc-100">
        Star on GitHub
      </h2>
      <p class="mt-5 max-w-2xl font-mono text-sm leading-7 text-[var(--aero-muted)]">
        Follow the project, watch the roadmap, and help more people find the self-hosted path.
      </p>
    </div>

    <a
      class="inline-flex min-h-16 items-center justify-center gap-3 border border-[rgba(79,184,178,0.62)] bg-[rgba(79,184,178,0.14)] px-7 font-mono text-sm font-bold uppercase tracking-[0.14em] text-[var(--aero-accent-strong)] transition hover:bg-[rgba(79,184,178,0.22)]"
      data-analytics-event="github_star_clicked"
      data-analytics-placement="github_star_section"
      href={githubUrl}
      rel="noreferrer"
      target="_blank"
    >
      <svg class="size-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="m12 2 2.98 6.04 6.67.97-4.82 4.7 1.14 6.64L12 17.22l-5.97 3.13 1.14-6.64-4.82-4.7 6.67-.97L12 2Z"></path>
      </svg>
      Star repo
    </a>
  </div>
</section>

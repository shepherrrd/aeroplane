<footer class="border-t border-[rgba(52,56,67,0.65)] bg-[#08090c] text-[var(--aero-muted)]">
  <div class="mx-auto flex w-[min(1180px,calc(100%_-_40px))] flex-col gap-5 py-10 font-mono text-sm md:flex-row md:items-center md:justify-between">
    <p class="m-0">Aeroplane. Deploy apps and databases on your own server.</p>
    <div class="flex flex-wrap gap-5 text-[var(--aero-text)]">
      <a
        data-analytics-event="github_link_clicked"
        data-analytics-placement="footer"
        href="https://github.com/xt42io/aeroplane"
        rel="noreferrer"
        target="_blank"
      >
        GitHub
      </a>
      <a
        data-analytics-event="install_link_clicked"
        data-analytics-placement="footer"
        href="https://get.aeroplane.run"
      >
        Install
      </a>
    </div>
  </div>
</footer>

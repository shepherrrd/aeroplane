---
const logoRows = [
  [
    { name: "React", icon: "https://svgl.app/library/react_dark.svg" },
    { name: "Next.js", icon: "https://svgl.app/library/nextjs_icon_dark.svg" },
    { name: "Astro", icon: "https://svgl.app/library/astro-icon-dark.svg" },
    { name: "Vite", icon: "https://svgl.app/library/vite.svg" },
    { name: "Node.js", icon: "https://svgl.app/library/nodejs.svg" },
    { name: "Svelte", icon: "https://svgl.app/library/svelte.svg" },
    { name: "Nuxt", icon: "https://svgl.app/library/nuxt.svg" },
    { name: "Bun", icon: "https://svgl.app/library/bun.svg" },
    { name: "Deno", icon: "/logos/deno-color.svg" },
    { name: "Docker", icon: "https://svgl.app/library/docker.svg" },
  ],
  [
    { name: "PostgreSQL", icon: "https://svgl.app/library/postgresql.svg" },
    { name: "Redis", icon: "https://svgl.app/library/redis.svg" },
    { name: "MongoDB", icon: "https://svgl.app/library/mongodb-icon-dark.svg" },
    { name: "MySQL", icon: "https://svgl.app/library/mysql-icon-dark.svg" },
    { name: "Prisma", icon: "/logos/prisma-color.svg" },
    { name: "Drizzle", icon: "https://svgl.app/library/drizzle-orm_dark.svg" },
    { name: "TanStack", icon: "https://svgl.app/library/tanstack.svg" },
    { name: "React Query", icon: "https://svgl.app/library/reactquery.svg" },
    { name: "Vitest", icon: "https://svgl.app/library/vitest.svg" },
    { name: "LangChain", icon: "https://svgl.app/library/langchain-logo.svg" },
  ],
  [
    { name: "Python", icon: "https://svgl.app/library/python.svg" },
    { name: "Rust", icon: "/logos/rust-color.svg" },
    { name: "Go", icon: "https://svgl.app/library/golang_dark.svg" },
    { name: "TypeScript", icon: "https://svgl.app/library/typescript.svg" },
    { name: "Hono", icon: "https://svgl.app/library/hono.svg" },
    { name: "Django", icon: "https://svgl.app/library/django.svg" },
    { name: "Laravel", icon: "https://svgl.app/library/laravel.svg" },
    { name: "NestJS", icon: "https://svgl.app/library/nestjs.svg" },
    { name: "Tailwind CSS", icon: "https://svgl.app/library/tailwindcss.svg" },
    { name: "Astro", icon: "https://svgl.app/library/astro-icon-dark.svg" },
  ],
];
---

<section class="relative overflow-hidden border-t border-[rgba(52,56,67,0.65)] bg-[#08090c] py-24 text-[var(--aero-text)]">
  <div
    class="pointer-events-none absolute inset-0 [background-image:linear-gradient(rgba(255,255,255,0.026)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.026)_1px,transparent_1px)] [background-size:72px_72px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-96 bg-[radial-gradient(ellipse_70%_50%_at_50%_0%,rgba(79,184,178,0.12),transparent)]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto w-[min(1180px,calc(100%_-_40px))]">
    <h2 class="font-hero m-0 text-[clamp(2.3rem,5vw,4.5rem)] font-bold leading-none text-zinc-100">
      Deploy anything
    </h2>
  </div>

  <div class="relative mt-14 grid gap-5">
    {logoRows.map((logos, index) => (
      <div class="logo-marquee overflow-hidden py-5">
        <div class={`logo-track flex w-max gap-12 pr-12 ${index % 2 === 1 ? "reverse" : ""}`}>
          {[...logos, ...logos, ...logos].map((logo) => (
            <div class="flex h-24 min-w-28 items-center justify-center px-2">
              <img class="size-16 object-contain" src={logo.icon} alt={`${logo.name} logo`} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .logo-track {
    animation: logo-marquee 46s linear infinite;
  }

  .logo-track.reverse {
    animation-direction: reverse;
  }

  .logo-marquee:hover .logo-track {
    animation-play-state: paused;
  }

  @keyframes logo-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-33.333%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-track {
      animation: none;
    }
  }
</style>

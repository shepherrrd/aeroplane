---
const command = "curl -fsSL https://get.aeroplane.run | sh";
---

<section id="install" class="aero-container py-12">
  <div class="aero-panel grid gap-6 p-6 md:grid-cols-[0.75fr_1.25fr] md:p-8">
    <div>
      <p class="text-sm font-bold text-[var(--aero-accent)]">INSTALL</p>
      <h2 class="mt-2 text-3xl font-black">One command on a fresh server.</h2>
      <p class="mt-4 leading-7 text-[var(--aero-muted)]">
        The installer pulls the Aeroplane image, starts BuildKit and Caddy, and leaves a compose stack in
        <code class="text-[var(--aero-text)]">/opt/aeroplane</code>.
      </p>
    </div>

    <div class="border border-[var(--aero-border)] bg-[#08090c] p-4">
      <div class="flex items-center justify-between border-b border-[var(--aero-border)] pb-3">
        <span class="text-sm font-bold text-[var(--aero-muted)]">Terminal</span>
        <span class="size-2 rounded-full bg-[var(--aero-accent)]"></span>
      </div>
      <pre class="overflow-x-auto pt-4 text-sm text-[var(--aero-accent-strong)]"><code>{command}</code></pre>
    </div>
  </div>
</section>
